{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "arrowParens": "always",
    "endOfLine": "lf",
    "ignorePatterns": ["dist", "node_modules", ".vite", "bun.lock", ".claude"]
}
